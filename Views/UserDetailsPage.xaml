<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FinalProjectAmit.Views.UserDetailsPage"
    Title="User Details"
    BackgroundColor="#99C1E9">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Start">

            <Label Text="ACCOUNT DETAILS"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2C3E50"
                   Margin="0,10,0,10"/>

            <Frame BackgroundColor="White" CornerRadius="5" Padding="15,5" HasShadow="False" BorderColor="Transparent">
                <Entry Placeholder="First Name"
                       PlaceholderColor="Gray"
                       Text="{Binding FirstName}"
                       TextColor="#333"
                       HorizontalTextAlignment="Center"/>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="5" Padding="15,5" HasShadow="False" BorderColor="Transparent">
                <Entry Placeholder="Last Name"
                       PlaceholderColor="Gray"
                       Text="{Binding LastName}"
                       TextColor="#333"
                       HorizontalTextAlignment="Center"/>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="5" Padding="15,5" HasShadow="False" BorderColor="Transparent">
                <Entry Placeholder="Email"
                       PlaceholderColor="Gray"
                       Keyboard="Email"
                       Text="{Binding UserEmail}"
                       TextColor="#333"
                       HorizontalTextAlignment="Center"/>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="5" Padding="15,5" HasShadow="False" BorderColor="Transparent">
                <Entry Placeholder="Mobile"
                       PlaceholderColor="Gray"
                       Keyboard="Telephone"
                       Text="{Binding Mobile}"
                       TextColor="#333"
                       HorizontalTextAlignment="Center"/>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="5" Padding="15,5" HasShadow="False" BorderColor="Transparent">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry Placeholder="Password"
                           PlaceholderColor="Gray"
                           IsPassword="{Binding EntryAsPassword}"
                           Text="{Binding UserPassword}"
                           TextColor="#333"
                           HorizontalTextAlignment="Center"
                           Grid.Column="0"/>

                    <ImageButton Source="{Binding PasswordImage}"
                                 Command="{Binding ShowPasswordCommand}"
                                 BackgroundColor="Transparent"
                                 HeightRequest="22"
                                 WidthRequest="22"
                                 VerticalOptions="Center"
                                 Grid.Column="1"/>
                </Grid>
            </Frame>

            <Button Text="UPDATE DETAILS"
                    Command="{Binding UpdateCommand}"
                    BackgroundColor="#E67E22"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="60"
                    CornerRadius="10"
                    Margin="0,10,0,0"/>

            <BoxView HeightRequest="1" 
                     BackgroundColor="White" 
                     HorizontalOptions="FillAndExpand" 
                     Margin="20,20,20,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>