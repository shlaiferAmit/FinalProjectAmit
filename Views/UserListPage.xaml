<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FinalProjectAmit.Views.UserListPage"
    Title="User List"
    BackgroundColor="#99C1E9">
    <VerticalStackLayout Padding="15" Spacing="10">

        <SearchBar
            Placeholder="Search user..."
            PlaceholderColor="Gray"
            TextColor="#2C3E50"
            BackgroundColor="White"
            Text="{Binding SearchText}"
            Margin="0,0,0,10" />

        <CollectionView
            ItemsSource="{Binding FilteredUsers}"
            SelectionMode="Single">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="15" 
                           Margin="0,5,0,5" 
                           BackgroundColor="White" 
                           HasShadow="False" 
                           BorderColor="Transparent"
                           CornerRadius="10">

                        <VerticalStackLayout Spacing="8">

                            <HorizontalStackLayout Spacing="5">
                                <Label Text="{Binding FirstName}" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50"/>
                                <Label Text="{Binding LastName}" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50"/>
                            </HorizontalStackLayout>

                            <Label Text="{Binding UserEmail}" 
                                   FontSize="14" 
                                   TextColor="#7F8C8D"
                                   Margin="0,-5,0,10"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="Edit"
                                        BackgroundColor="#E67E22"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        HeightRequest="40"
                                        CornerRadius="5"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToEditCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Grid.Column="1"
                                        Text="Delete"
                                        BackgroundColor="#E74C3C"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        HeightRequest="40"
                                        CornerRadius="5"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteUserCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>